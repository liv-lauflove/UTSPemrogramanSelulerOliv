<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvSapaan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selamat bertugas, Dosen -"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:textColor="#333333"/>

        <EditText
            android:id="@+id/inputJmlMhs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Jumlah Mahasiswa"
            android:inputType="number"
            android:minHeight="48dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/inputRataRata"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Rata-rata Nilai Kelas (Contoh: 85)"
            android:inputType="numberDecimal"
            android:minHeight="48dp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnProses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PROSES DATA"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status Kelas: -"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvDaftarAbsen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daftar Absen akan muncul di sini"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.5"/>

    </LinearLayout>
</ScrollView>