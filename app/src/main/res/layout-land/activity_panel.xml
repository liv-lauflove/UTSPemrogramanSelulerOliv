<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    android:orientation="horizontal"
    android:weightSum="2"
    android:padding="16dp">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:fillViewport="true"
        android:layout_marginEnd="8dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:contentPadding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSapaan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sapaan..."
                    android:textColor="#2C3E50"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/inputJmlMhs"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Jumlah Mahasiswa"
                    android:inputType="number"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/inputRataRata"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Rata-rata Nilai"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnProses"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:backgroundTint="#2C3E50"
                    android:text="PROSES DATA"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </ScrollView>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:fillViewport="true"
        android:layout_marginStart="8dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:contentPadding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status Kelas: -"
                    android:textColor="#27AE60"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvDaftarAbsen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Daftar absen..."
                    android:textColor="#34495E"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.4"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </ScrollView>

</LinearLayout>